# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=erp_db

# ─── JWT RS256 ─────────────────────────────────────────────────────────────────
# Generate key pair:
#   openssl genrsa -out private.key 2048
#   openssl rsa -in private.key -pubout -out public.key
#   base64 -w 0 private.key  → JWT_PRIVATE_KEY_BASE64
#   base64 -w 0 public.key   → JWT_PUBLIC_KEY_BASE64
JWT_PRIVATE_KEY_BASE64=CHANGE_ME
JWT_PUBLIC_KEY_BASE64=CHANGE_ME
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Throttle ─────────────────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ─── Seeds ────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@erp.com
SEED_ADMIN_PASSWORD=Admin1234!

# ─── WhatsApp (Meta Cloud API) — optional, see docs/whatsapp-meta-setup.md ─────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v21.0
# UUID of the company this WhatsApp number belongs to (see companies list in the admin panel)
WHATSAPP_COMPANY_ID=
